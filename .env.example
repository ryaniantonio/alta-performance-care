# Variáveis de ambiente do projeto — TEMPLATE versionado.
# NÃO coloque segredos reais neste arquivo (ele vai para o Git).
#
# Modelo de configuração (ver docs/environment-variables.md):
#
#   .env         (VERSIONADO)  -> SOMENTE variáveis públicas (VITE_* e Supabase anon).
#                                 O Vite as inlina em build-time; a build do Vercel
#                                 (produção) e do Lovable (preview de UI) dependem delas.
#                                 São públicas por design, protegidas por RLS.
#   .env.local   (IGNORADO)    -> SEGREDOS para desenvolvimento local. Coberto pelo
#                                 `*.local` do .gitignore; nunca é commitado.
#   Vercel > Environment Variables -> SEGREDOS de PRODUÇÃO.
#
# Para desenvolver localmente: crie um `.env.local` e preencha o bloco de SEGREDOS
# abaixo (as variáveis públicas já vêm do `.env` versionado; o Vite mescla os dois).

# ---------------------------------------------------------------------------
# PÚBLICAS — já presentes no `.env` versionado (chaves publishable/anon do Supabase).
# ---------------------------------------------------------------------------
SUPABASE_PROJECT_ID="seu-project-id"
SUPABASE_URL="https://seu-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"

# ---------------------------------------------------------------------------
# SEGREDOS — NUNCA versionar. Vão em `.env.local` (dev) e no Vercel (produção).
# Lidos apenas no SERVIDOR (process.env), nunca no bundle do cliente.
# ---------------------------------------------------------------------------

# Supabase service-role: IGNORA a RLS (acesso total ao banco). Só servidor.
# SUPABASE_SERVICE_ROLE_KEY="defina-no-.env.local-e-no-Vercel"

# E-mail (SMTP Gmail) — consumido por server function (Vercel Node suporta SMTP).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# SERVER_SECURE=true
# EMAIL_USER="voce@gmail.com"
# EMAIL_PASS="senha-de-app-do-gmail"
# EMAIL_FROM="Alta Performance Care <voce@gmail.com>"
